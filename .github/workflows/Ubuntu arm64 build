name: PRoot-Compatible ARM64 Build

on:
  push:
    branches: [ main ]
  workflow_dispatch:

jobs:
  build:
    # Native ARM64 runner provided by GitHub (GA as of 2025)
    runs-on: ubuntu-24.04-arm
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Install System Dependencies
        run: |
          sudo apt-get update
          sudo apt-get install -y pkg-config libssl-dev

      - name: Install Rust
        uses: dtolnay/rust-toolchain@stable

      - name: Build Arnis (Release)
        run: cargo build --release

      - name: Upload PRoot Binary
        uses: actions/upload-artifact@v4
        with:
          name: arnis-proot-arm64
          path: target/release/arnis
